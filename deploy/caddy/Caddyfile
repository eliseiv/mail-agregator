# ---------------------------------------------------------------------------
# Caddy 2 — TLS termination + reverse proxy for mail-aggregator (prod profile)
#
# - Auto-issues Let's Encrypt cert for {$CADDY_DOMAIN}
# - Forwards everything to api:8080 on the docker network
# - Adds long cache headers for /static/*
# - HSTS only here (not in app code) so it stays consistent with TLS rollout
#
# Source: docs/07-deployment.md sec.6.
# ---------------------------------------------------------------------------

{
    # Global options
    email                {$CADDY_ACME_EMAIL:admin@example.com}
    admin                :2019
    # Reasonable default; turn on `debug` when troubleshooting.
}

{$CADDY_DOMAIN} {
    encode zstd gzip

    # Long-lived static assets (vanilla CSS/JS hashed on path if needed).
    @static path /static/*
    handle @static {
        reverse_proxy api:8080
        header Cache-Control "public, max-age=86400"
    }

    handle {
        reverse_proxy api:8080 {
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-For   {remote_host}
            header_up X-Real-IP         {remote_host}
            # Pass the request id back so app logs and proxy logs correlate.
            header_up X-Request-ID      {http.request.header.X-Request-ID}
        }
    }

    # Security headers — values match docs/06-security.md sec.6.
    # CSP, X-Frame-Options, etc. are set by the app on HTML responses;
    # Caddy only owns HSTS because it owns TLS.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Defence in depth — also strip the Server header so we don't
        # advertise the proxy version to scanners.
        -Server
    }

    log {
        output stdout
        format json
    }
}
