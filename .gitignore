# ---------------------------------------------------------------------------
# Secrets & local configuration — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/
*.gpg

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual envs
.venv/
venv/
env/
ENV/

# Tooling caches / reports
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
.tox/
.nox/
nosetests.xml
.dmypy.json
dmypy.json
.cache/

# uv
# (uv.lock IS committed; only the venv it builds is ignored — covered by .venv/)

# ---------------------------------------------------------------------------
# IDE / editors
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Logs / runtime
# ---------------------------------------------------------------------------
*.log
logs/
*.pid

# ---------------------------------------------------------------------------
# Docker / local volumes (named volumes live in Docker, not on FS, but
# defensively ignore any local mounts a developer might bind)
# ---------------------------------------------------------------------------
.docker/
docker-data/
docker-compose.override.yml

# ---------------------------------------------------------------------------
# Node (frontend is vanilla, but devs may run linters/formatters)
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*

# ---------------------------------------------------------------------------
# OS junk
# ---------------------------------------------------------------------------
desktop.ini

.claude
CLAUDE.md

# ---------------------------------------------------------------------------
# Local scratch / manual-smoke files (never committed; kept out of ruff too,
# since ruff respects .gitignore by default — see CI `ruff check .`).
# ---------------------------------------------------------------------------
smoke_test.py
_rt_*
_rev_*
_smoke_*
docker-compose.qa-local.yml
*.jpg