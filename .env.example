# ===========================================================================
# Mail Aggregator — environment template
#
# Copy this file:    cp .env.example .env
# Then fill in:      every value marked "change_me_..." or "REQUIRED"
# Lock down perms:   chmod 600 .env   (Linux / WSL; not relevant on Windows)
#
# Source of truth for variable names + defaults:
#   docs/07-deployment.md  sec.4
#   docs/06-security.md    sec.10, sec.12
#
# Convention: blocks are grouped by concern; comments explain what generates
# each secret. Never commit a real .env to git (.env is in .gitignore).
# ===========================================================================


# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
# Affects CSP, cookie Secure flag, ENABLE_DOCS gating, SSRF allowlist.
# Only `dev` and `prod` are meaningful.
APP_ENV=dev

# Public origin used to build absolute URLs (Message-ID, redirect targets).
# In dev, leave as http://localhost:8080. In prod set to https://your.domain.
APP_BASE_URL=http://localhost:8080

# DEBUG / INFO / WARNING / ERROR. Stick to INFO in prod.
LOG_LEVEL=INFO

# Open /docs Swagger UI. Forced to false when APP_ENV=prod regardless.
ENABLE_DOCS=true


# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=mas
POSTGRES_DB=mail_aggregator
# generate: openssl rand -base64 32 | tr -d '/+=' | head -c 32
POSTGRES_PASSWORD=change_me_postgres_password

# Full DSN consumed by the app. Compose substitutes ${POSTGRES_PASSWORD}
# from the line above; you almost never need to edit this directly.
DATABASE_URL=postgresql+asyncpg://mas:change_me_postgres_password@postgres:5432/mail_aggregator


# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
# Set to "yes" to enable AOF persistence (sessions survive redis restart).
# Default "no" is fine — sessions are recoverable by re-login.
REDIS_APPENDONLY=no


# ---------------------------------------------------------------------------
# Crypto — mail-account password encryption (AES-256-GCM)
# ---------------------------------------------------------------------------
# REQUIRED. 32 bytes, base64-encoded.
# generate: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# Losing this key permanently bricks all stored mail-account passwords.
# Store a copy off-site (password manager / sealed env).
MAIL_ENCRYPTION_KEY=change_me_base64_32_bytes_required

# Only set during a key-rotation window. Empty otherwise.
# Same format as MAIL_ENCRYPTION_KEY.
MAIL_ENCRYPTION_KEY_PREV=


# ---------------------------------------------------------------------------
# Worker / sync tuning
# ---------------------------------------------------------------------------
# Concurrent IMAP connections cap (semaphore). Raising costs memory + risk
# of provider rate-limits. Default 10 from ADR-0013.
MAX_CONCURRENT_IMAP=10

# Default ThreadPoolExecutor size = MAX_CONCURRENT_IMAP + 4.
WORKER_THREAD_POOL_SIZE=14

# Sync cycle interval. Do not go below 3 (provider abuse).
SYNC_INTERVAL_MINUTES=5

# Per-account IMAP timeout (seconds) — worker sync only, NOT the connection
# test (see MAILBOX_TEST_DEADLINE_SECONDS below).
IMAP_TIMEOUT_SECONDS=60

# ADR-0047: hard deadline for the WHOLE mailbox connection test
# (host-assert + IMAP login + SMTP login). Applies to POST /mailboxes/test,
# POST /mailboxes and PATCH /mailboxes/{id} when credentials change — they all
# go through MailAccountService.test().
#
# Exceeding it yields a DOMAIN error 422 (imap_login_failed / smtp_login_failed
# with details.detail="timeout") — never a hang and never a raw nginx 504.
#
# This deadline is the ONLY upper bound of the PROBE — but NOT of the response.
# Two more legs are budgeted separately (ADR-0047 sec. 2.1/2.3/5):
#   - teardown after cancellation (<= 5s): asyncio.wait_for AWAITS the cancelled
#     task, including the ``finally: await _close_smtp_client(client)`` of the SMTP
#     probe — a polite QUIT time-boxed by _SMTP_QUIT_TIMEOUT = 5
#     (accounts/testers.py:65). Without that time-box a silent server would drag
#     QUIT for _SMTP_TIMEOUT = 20 → 45 + 20 = 65 > 60 → guaranteed 504.
#   - off-probe part of the request (<= 5s): auth, mailbox SELECT + password
#     decrypt, INSERT/UPDATE, DTO serialization.
#
# INVARIANT (normative bounds: ge=10, le=45 — worst case 45 + 5 + 5 = 55 < 60):
#   MAILBOX_TEST_DEADLINE_SECONDS 45  +  teardown <= 5  +  off-probe <= 5   <   60
#                                                            (nginx proxy_read_timeout
#                                                             = gunicorn --timeout)
#   le formula: le <= 60 - teardown(5) - off-probe(5) - reserve(5) = 45
#
# The bound is machine-enforced: shared/config.py declares Field(ge=10, le=45), so
# a value above 45 fails validation at startup (TD-058 closed). The old le=50 is
# revoked: at 50 the worst case was exactly 60 = the proxy timeout, i.e. the very
# 504 HTML this ADR exists to prevent.
#
# The domain 422 MUST surface BEFORE nginx turns the wait into a 504 HTML page,
# otherwise the real failure reason never reaches the user. If you change nginx
# proxy_read_timeout, re-check this chain (docs/07-deployment.md sec. 6).
#
# NOT part of the invariant: _IMAP_TIMEOUT + _SMTP_TIMEOUT (20 + 20 = 40) in
# accounts/testers.py. Those are SOCKET timeouts applied per operation/phase,
# not to the whole login, so they bound nothing — they are a fail-fast budgeting
# heuristic (that is exactly why IMAP needed its own +5 guard). See ADR-0047 2.2.
#
# Outward chain (CRM side, normative in CRM ADR-053 sec. 1.1/1.2/1.2.1/6 — do not set
# it here):
#   45 < 60 (our nginx) < 75 (CRM read) < 85 (CRM overall deadline of ONE call)
# CRM's outermost link is budgeted PER REQUEST, not per call (ADR-053 sec. 1.2.1):
#   sum(overall deadlines of all calls in the request) + CRM non-probe work (<=5)
#     < CRM nginx proxy_read_timeout = 120
#   worst CRM path (create + compensating orphan delete): 85 + 15 + 5 = 105 < 120
# The old "CRM nginx 90" link is REVOKED (ADR-053 sec. 6): it bounded a single call
# and broke on the two-call path (85 + compensation -> 115 > 90).
MAILBOX_TEST_DEADLINE_SECONDS=45

# Window for the very first fetch on a new account.
INITIAL_SYNC_DAYS=30

# Message TTL (days). Older messages are purged by cleanup job.
RETENTION_DAYS=30


# ---------------------------------------------------------------------------
# Session guards — runtime detector of dropped status events
# (ADR-0046 §2.1.1 / TD-054). A DB session — the connector has no user
# sessions/cookies at all (ADR-0044 Phase A3 removed interactive login).
#
# Detects a caller that wrote a mailbox status change and forgot
# flush_crm_status_events() (the event would otherwise be lost silently).
# Checked at the teardown of EVERY DB session (shared/db.py).
#
#   unset (this file's default)  -> strict mode ON only under pytest
#                                   (PYTEST_CURRENT_TEST); OFF in prod:
#                                   a violation is logged as a structlog
#                                   warning `crm_status_pending_dropped`
#                                   and the already-committed request still
#                                   returns 200.
#   1 | true | yes | on           -> strict: hard AssertionError after the
#                                   warning. For dev/staging debugging only.
#   any other value (incl. empty) -> strict OFF, even under pytest.
#
# LEAVE IT COMMENTED OUT. An explicit `SESSION_GUARD_STRICT=` (empty value)
# is NOT the same as unset — it force-disables strict mode, including on CI.
# Never set it to true in prod: a forgotten flush would turn an
# already-COMMITted PATCH into a 500.
# ---------------------------------------------------------------------------
# SESSION_GUARD_STRICT=true


# ---------------------------------------------------------------------------
# Reverse proxy + TLS (nginx + certbot, prod profile only)
# ---------------------------------------------------------------------------
# REQUIRED for `docker compose --profile prod up`. FQDN with valid DNS A record
# pointing at this server's public IP. nginx envsubst's this into
# /etc/nginx/conf.d/default.conf at container start, and certbot uses it to
# request Let's Encrypt certs.
SERVER_DOMAIN=
# Used by ACME for cert renewal notices (and reset emails for the LE account).
# Set to a real address you monitor.
ACME_EMAIL=admin@example.com
#
# First-time TLS bootstrap (on the prod host, after the rest of the stack is up):
#
#   docker compose run --rm -p 80:80 certbot certonly --standalone \
#     -d "$SERVER_DOMAIN" --email "$ACME_EMAIL" --agree-tos --no-eff-email
#
# Then start nginx + certbot for ongoing renewal:
#   docker compose --profile prod up -d nginx certbot
#
# Detailed walkthrough: docs/SERVER-SETUP.md.


# ---------------------------------------------------------------------------
# External API — authentication (ADR-0029). API only.
#
# Static API key authenticating the WHOLE external API — the only surface the
# CRM talks to after the decommission (ADR-0044). Sent as `X-API-Key: <key>`
# (or `Authorization: Bearer <key>`) on:
#   GET  /api/external/messages                  pull (ADR-0029)
#   GET  /api/external/mailboxes                 pull / reconcile
#   POST/PATCH/DELETE /api/external/mailboxes*   write section (block below)
#   POST /api/external/mailboxes/{id}/send       generic send (ADR-0048)
#
# generate: openssl rand -hex 32   (256-bit)
# Compared in constant time (secrets.compare_digest) and redacted in
# shared/logging.py alongside X-API-Key / Authorization.
#
# OPTIONAL: empty ⇒ the external API is OFF — every endpoint answers 401
# unenumerably (feature-off is indistinguishable from a wrong key; the config is
# never disclosed). Leave empty in dev/CI to wire the routes without a key.
# REQUIRED for the CRM connector to work.
# ---------------------------------------------------------------------------
EXTERNAL_API_KEY=change_me_external_api_key

# Per-IP rate limit for the read/pull section: requests per 60s window.
# Numeric (requests/60s) — NOT a "120/minute" string. Window is fixed at 60s.
EXTERNAL_API_RATE_LIMIT_PER_MINUTE=120


# ---------------------------------------------------------------------------
# External write API — mailboxes CRUD (ADR-0039). API only.
#
# The external API is authenticated by EXTERNAL_API_KEY (above) alone. The
# headless-CRM WRITE section additionally requires an explicit opt-in,
# EXTERNAL_WRITE_ENABLED=true, on top of a valid key:
#   POST   /api/external/mailboxes/test          probe IMAP/SMTP, no persistence
#   POST   /api/external/mailboxes               create (owner = crm-service)
#   PATCH  /api/external/mailboxes/{id}          update
#   DELETE /api/external/mailboxes/{id}          delete
#   POST   /api/external/mailboxes/{id}/sync     force-sync
#   POST   /api/external/mailboxes/{id}/send     generic send (ADR-0048)
#   POST   /api/external/mailboxes/oauth/authorize  headless Outlook (ADR-0045)
# Default false keeps a read-only deployment read-only after an upgrade (a valid
# key does NOT silently gain write capability); when false every endpoint above
# returns 403 forbidden even with a valid key.
# (The OAuth *callback* is NOT behind this gate — it carries no key and is
# authorised by the one-shot Redis state + PKCE. See the Outlook block below.)
#
# EXTERNAL_WRITE_RATE_LIMIT_PER_MINUTE is a SEPARATE per-IP budget from read
# (120) — write is more expensive / abuse-sensitive, so the two must not share
# (no mutual eviction between pull and write). Numeric; window fixed at 60s.
#
# Gone with the decommission (ADR-0044 §4) — do NOT expect these any more:
# the tags CRUD section (/api/external/tags*, ADR-0039/ADR-0040; tag matching
# moved into the CRM) and the reply endpoint (ADR-0035) with its own 30/min
# budget, superseded by the generic send above (ADR-0048).
# ---------------------------------------------------------------------------
EXTERNAL_WRITE_ENABLED=false
EXTERNAL_WRITE_RATE_LIMIT_PER_MINUTE=60


# ---------------------------------------------------------------------------
# Outlook OAuth2 — headless external consent (ADR-0025 + ADR-0045 §4). API only.
#
# Azure App credentials (personal Microsoft accounts). The routes
# /api/external/mailboxes/oauth/* serve real flows only when BOTH the client id
# and the secret are set (outlook_oauth_enabled); otherwise they return 404 —
# the feature is hidden, not merely disabled. Leave empty in dev/CI to wire the
# routes without a real Azure App.
# ---------------------------------------------------------------------------
OUTLOOK_CLIENT_ID=change_me_outlook_client_id
# SECRET. Redacted in shared/logging.py (alongside MAIL_ENCRYPTION_KEY).
OUTLOOK_CLIENT_SECRET=change_me_outlook_client_secret

# Registered Azure redirect_uri — MUST match the Azure App registration exactly.
# ADR-0045 §4 (amends ADR-0044 Phase G): the headless external-OAuth callback
# replaced the removed session callback, so the value is
#   {APP_BASE_URL}/api/external/mailboxes/oauth/callback
# e.g. https://your.domain/api/external/mailboxes/oauth/callback
# The code only reads this env value — changing it also requires editing the
# Azure App registration.
OUTLOOK_REDIRECT_URI=

# Tenant segment of the authorize/token endpoints. ADR-0025: `consumers` for
# personal mailboxes — the working configuration. The switch to `common` did NOT
# fix the prod "authenticated but not connected" symptom and was reverted.
OUTLOOK_TENANT=consumers

# TTL of the Redis oauth_state:{state} key (CSRF/anti-fixation state + PKCE
# verifier), seconds. Default 600 per ADR-0025 §6.
OUTLOOK_OAUTH_STATE_TTL_SECONDS=600


# ---------------------------------------------------------------------------
# CRM push connector (ADR-0043 §2). WORKER only.
#
# The aggregator becomes a thin mail-connector: it PUSHes every newly synced
# message to the CRM and mirrors mailbox sync-status changes. Both channels
# authenticate with an HMAC-SHA256 signature over the raw request body
# (X-Mail-Signature: sha256=<hex>, X-Mail-Timestamp: <unix>), keyed by the
# shared CRM_PUSH_SECRET (= the CRM side's MAIL_PUSH_SECRET).
#
# The channel stays OFF until BOTH the URL and CRM_PUSH_SECRET are set — a
# pre-cut-over deployment keeps working unchanged (jobs not registered,
# sync_cycle does not enqueue). Set these during cut-over prep.
#
#   CRM_INGEST_URL          -> POST {CRM_INGEST_URL}/api/mail/ingest
#   CRM_MAILBOX_STATUS_URL  -> POST {CRM_MAILBOX_STATUS_URL}/api/mail/mailbox-status
#   CRM_PUSH_SECRET         -> shared HMAC secret (openssl rand -hex 32). SECRET.
# ---------------------------------------------------------------------------
CRM_INGEST_URL=
CRM_MAILBOX_STATUS_URL=
CRM_PUSH_SECRET=
# CRM caps the ingest batch at 100 (ADR-044 §3) — do not exceed.
CRM_PUSH_BATCH_SIZE=100
CRM_PUSH_DISPATCH_INTERVAL_SECONDS=5
CRM_PUSH_RECOVERY_INTERVAL_SECONDS=3600
CRM_PUSH_RECOVERY_WINDOW_HOURS=720
CRM_PUSH_RECOVERY_BATCH_SIZE=500
CRM_STATUS_DISPATCH_INTERVAL_SECONDS=5
CRM_STATUS_BATCH_SIZE=30
CRM_PUSH_HTTP_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# External Outlook OAuth ingest (ADR-0045 §3). BACKEND only.
#
# The headless external-OAuth callback (GET /api/external/mailboxes/oauth/callback)
# notifies the CRM of the created/relinked mailbox↔team binding with the SAME
# HMAC scheme + reused CRM_PUSH_SECRET as /api/mail/ingest:
#   CRM_OAUTH_INGEST_URL -> POST {CRM_OAUTH_INGEST_URL} (= CRM /api/mail/oauth/ingest)
# Empty ⇒ the notification is not sent (endpoint effectively off, symmetric
# with the status channel). Best-effort — a failure never rolls back the box.
# ---------------------------------------------------------------------------
CRM_OAUTH_INGEST_URL=


# ---------------------------------------------------------------------------
# CI / Build (optional)
# ---------------------------------------------------------------------------
# Image registry prefix.
#   - Local builds (developer machines):  leave empty -> resolves to
#       mail-aggregator/api:${IMAGE_TAG} which `docker compose build` writes.
#   - Prod servers pulling CI-published images: set to the GHCR path, e.g.
#       IMAGE_REGISTRY=ghcr.io/<owner>/<repo>
#     This makes compose pull `ghcr.io/<owner>/<repo>/api:<tag>` instead of
#     trying to rebuild locally.
IMAGE_REGISTRY=

# Tag baked into the image name (${IMAGE_REGISTRY}/api:${IMAGE_TAG}).
# CI sets this to ${{ github.sha }} or a release tag; on the prod server,
# the deploy workflow rewrites this in .env to the freshly-pushed sha.
IMAGE_TAG=local
