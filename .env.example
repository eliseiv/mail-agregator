# ===========================================================================
# Mail Aggregator — environment template
#
# Copy this file:    cp .env.example .env
# Then fill in:      every value marked "change_me_..." or "REQUIRED"
# Lock down perms:   chmod 600 .env   (Linux / WSL; not relevant on Windows)
#
# Source of truth for variable names + defaults:
#   docs/07-deployment.md  sec.4
#   docs/06-security.md    sec.10, sec.12
#
# Convention: blocks are grouped by concern; comments explain what generates
# each secret. Never commit a real .env to git (.env is in .gitignore).
# ===========================================================================


# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
# Affects CSP, cookie Secure flag, ENABLE_DOCS gating, SSRF allowlist.
# Only `dev` and `prod` are meaningful.
APP_ENV=dev

# Public origin used to build absolute URLs (Message-ID, redirect targets).
# In dev, leave as http://localhost:8080. In prod set to https://your.domain.
APP_BASE_URL=http://localhost:8080

# DEBUG / INFO / WARNING / ERROR. Stick to INFO in prod.
LOG_LEVEL=INFO

# Open /docs Swagger UI. Forced to false when APP_ENV=prod regardless.
ENABLE_DOCS=true


# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=mas
POSTGRES_DB=mail_aggregator
# generate: openssl rand -base64 32 | tr -d '/+=' | head -c 32
POSTGRES_PASSWORD=change_me_postgres_password

# Full DSN consumed by the app. Compose substitutes ${POSTGRES_PASSWORD}
# from the line above; you almost never need to edit this directly.
DATABASE_URL=postgresql+asyncpg://mas:change_me_postgres_password@postgres:5432/mail_aggregator


# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
# Set to "yes" to enable AOF persistence (sessions survive redis restart).
# Default "no" is fine — sessions are recoverable by re-login.
REDIS_APPENDONLY=no


# ---------------------------------------------------------------------------
# MinIO — TWO key pairs (least-privilege, see docs/06-security.md sec.12)
#
# ROOT keys:  used ONLY by the minio container itself + the bootstrap init
#             container. NEVER passed into api/worker.
# APP keys:   service account created by minio-bootstrap, scoped to the
#             attachments bucket only. api/worker use ONLY these.
# ---------------------------------------------------------------------------

# generate: openssl rand -hex 16
MINIO_ROOT_USER=change_me_minio_root_user
# generate: openssl rand -base64 48 | tr -d '/+=' | head -c 40
MINIO_ROOT_PASSWORD=change_me_minio_root_password

# generate: openssl rand -hex 16
MINIO_APP_ACCESS_KEY=change_me_minio_app_access_key
# generate: openssl rand -base64 48 | tr -d '/+=' | head -c 40
MINIO_APP_SECRET_KEY=change_me_minio_app_secret_key

# What api/worker see. These ARE the MINIO_APP_* values; never set them
# to MINIO_ROOT_*. Compose wires this automatically — do not change.
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=change_me_minio_app_access_key
S3_SECRET_KEY=change_me_minio_app_secret_key
S3_BUCKET_NAME=mail-attachments
S3_REGION=us-east-1


# ---------------------------------------------------------------------------
# Crypto — mail-account password encryption (AES-256-GCM)
# ---------------------------------------------------------------------------
# REQUIRED. 32 bytes, base64-encoded.
# generate: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# Losing this key permanently bricks all stored mail-account passwords.
# Store a copy off-site (password manager / sealed env).
MAIL_ENCRYPTION_KEY=change_me_base64_32_bytes_required

# Only set during a key-rotation window. Empty otherwise.
# Same format as MAIL_ENCRYPTION_KEY.
MAIL_ENCRYPTION_KEY_PREV=


# ---------------------------------------------------------------------------
# Super-admin seed (idempotent; runs at every api start)
# ---------------------------------------------------------------------------
ADMIN_LOGIN=admin
# REQUIRED. Recommended >= 16 chars. To rotate: edit this and
# `docker compose restart api worker` (see docs/07-deployment.md sec.11.1).
ADMIN_PASSWORD=change_me_admin_password


# ---------------------------------------------------------------------------
# Worker / sync tuning
# ---------------------------------------------------------------------------
# Concurrent IMAP connections cap (semaphore). Raising costs memory + risk
# of provider rate-limits. Default 10 from ADR-0013.
MAX_CONCURRENT_IMAP=10

# Default ThreadPoolExecutor size = MAX_CONCURRENT_IMAP + 4.
WORKER_THREAD_POOL_SIZE=14

# Sync cycle interval. Do not go below 3 (provider abuse).
SYNC_INTERVAL_MINUTES=5

# Per-account IMAP timeout (seconds).
IMAP_TIMEOUT_SECONDS=60

# Window for the very first fetch on a new account.
INITIAL_SYNC_DAYS=30

# Message TTL (days). Older messages are purged by cleanup job.
RETENTION_DAYS=30

# Hard cap per attachment (bytes). 25 MiB.
MAX_ATTACHMENT_BYTES=26214400


# ---------------------------------------------------------------------------
# Sessions / auth (advanced — defaults are fine)
# ---------------------------------------------------------------------------
# Sliding TTL of a regular user session (seconds). 12h.
SESSION_TTL_SECONDS=43200

# Hard upper bound on session lifetime (seconds). 7 days.
SESSION_ABSOLUTE_TTL_SECONDS=604800

# Set-password setup-session TTL (seconds). 15 minutes.
SETUP_SESSION_TTL_SECONDS=900

# Optional explicit cookie domain (e.g. ".example.com"). Empty = host-only.
COOKIE_DOMAIN=


# ---------------------------------------------------------------------------
# Reverse proxy + TLS (nginx + certbot, prod profile only)
# ---------------------------------------------------------------------------
# REQUIRED for `docker compose --profile prod up`. FQDN with valid DNS A record
# pointing at this server's public IP. nginx envsubst's this into
# /etc/nginx/conf.d/default.conf at container start, and certbot uses it to
# request Let's Encrypt certs.
SERVER_DOMAIN=
# Used by ACME for cert renewal notices (and reset emails for the LE account).
# Set to a real address you monitor.
ACME_EMAIL=admin@example.com
#
# First-time TLS bootstrap (on the prod host, after the rest of the stack is up):
#
#   docker compose run --rm -p 80:80 certbot certonly --standalone \
#     -d "$SERVER_DOMAIN" --email "$ACME_EMAIL" --agree-tos --no-eff-email
#
# Then start nginx + certbot for ongoing renewal:
#   docker compose --profile prod up -d nginx certbot
#
# Detailed walkthrough: docs/SERVER-SETUP.md.


# ---------------------------------------------------------------------------
# Telegram bot / persistent SSO / push-notifications
# (ADR-0018 launcher + ADR-0022 SSO + notifications)
# ---------------------------------------------------------------------------
# Bot API token from BotFather. Empty → bot is disabled (route still works
# but webhook + push-notifications silently no-op). Required in prod if
# Telegram features are in use.
BOT_TOKEN=
# Shared secret used both in the webhook URL path and the
# ``X-Telegram-Bot-Api-Secret-Token`` header on inbound updates.
# generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
# Public HTTPS origin where Telegram WebApp opens the service
# (e.g. https://mail.example.com). Required for ``/start`` to send a
# working WebApp button.
TELEGRAM_WEBAPP_URL=

# ADR-0022 §1 — Persistent SSO tunables. Defaults are sane; do not lower
# below 60s without a reason.
# TTL for initData.auth_date (5 min).
TG_AUTH_INIT_DATA_TTL_SECONDS=300
# TTL for the ``mas_tg_pending`` cookie / Redis token (15 min).
TG_PENDING_LINK_TTL_SECONDS=900

# ADR-0022 §2 — Push-notifications. Worker container reads these.
# Dispatch tick interval (drain Redis queue).
TG_NOTIFY_DISPATCH_INTERVAL_SECONDS=5
# Recovery scan interval (re-enqueue lost notifications).
TG_NOTIFY_RECOVERY_INTERVAL_SECONDS=3600
# Recovery lookback window (hours).
TG_NOTIFY_RECOVERY_WINDOW_HOURS=24
# Per-tick LPOP batch size.
TG_NOTIFY_BATCH_SIZE=30
# Per-tick recovery LPUSH batch size.
TG_NOTIFY_RECOVERY_BATCH_SIZE=200

# ADR-0027 — Push-only per-team Telegram bots. round-42: needed in BOTH the
# worker container (notification delivery) AND the api container (callback
# webhook). round-44: four push-only bots (added business2). Each delivers ALL
# mail of ITS team (bound by an explicit group_id) to the fixed
# ADMIN_TELEGRAM_IDS. Leave the tokens empty to keep a bot (and the whole
# channel) off. Prod mapping:
# ivan=group_id 1, alexandra=2, andrei=3 (ADR-0027 §1); business2=group_id set
# by operator, MUST differ from 1/2/3 (duplicate group_id -> start fail-fast,
# ADR-0027 §2). chmod 600 the .env —
# the tokens are as sensitive as BOT_TOKEN.
# round-42: BOT_*_WEBHOOK_SECRET (32 hex, `openssl rand -hex 16`) enables the
# "Посмотреть сообщение" callback button + per-bot webhook (ADR-0027 §2/§10).
# Empty secret -> that bot sends notifications WITHOUT a button (graceful
# degradation). Register each push webhook at deploy: see 07-deployment §14.3-push.
# Команда ivan
BOT_IVAN_TOKEN=
BOT_IVAN_GROUP_ID=1
BOT_IVAN_WEBHOOK_SECRET=
# Команда alexandra
BOT_ALEXANDRA_TOKEN=
BOT_ALEXANDRA_GROUP_ID=2
BOT_ALEXANDRA_WEBHOOK_SECRET=
# Команда andrei
BOT_ANDREI_TOKEN=
BOT_ANDREI_GROUP_ID=3
BOT_ANDREI_WEBHOOK_SECRET=
# Команда business2 (round-44, ADR-0027). group_id команды business2 — задаёт
# оператор, ДОЛЖЕН отличаться от 1/2/3 (дубль -> fail-fast старта, §2);
# 0 = не настроен. webhook_secret = openssl rand -hex 16.
BOT_BUSINESS2_TOKEN=
BOT_BUSINESS2_GROUP_ID=0
BOT_BUSINESS2_WEBHOOK_SECRET=
# Fixed admin recipients — 2 Telegram chat id через запятую (e.g. 111,222).
# Empty -> the push channel is disabled entirely.
ADMIN_TELEGRAM_IDS=
# Push dispatch tick interval (drain push_notify_queue).
PUSH_NOTIFY_DISPATCH_INTERVAL_SECONDS=5
# Per-tick LPOP batch size.
PUSH_NOTIFY_BATCH_SIZE=30


# ---------------------------------------------------------------------------
# Mail forwarding — service SMTP relay (ADR-0034 §5.1). Worker container.
#
# OPTIONAL. Leave HOST/FROM/USERNAME empty to keep the historical behaviour:
# forwards are sent with the RECEIVING mailbox's own SMTP credentials.
# Set all three (HOST + FROM + USERNAME) to route every forward through a
# dedicated service relay instead — needed when the monitoring mailboxes
# cannot send themselves (Gmail app-password revoked, AOL drops the
# connection, Outlook OAuth without the SMTP.Send scope). In relay mode the
# forward's From = FORWARD_SMTP_FROM and Reply-To = the original sender.
# ---------------------------------------------------------------------------
FORWARD_SMTP_HOST=
FORWARD_SMTP_PORT=587
FORWARD_SMTP_USERNAME=
# Secret — chmod 600 .env; masked in structlog redact-list.
FORWARD_SMTP_PASSWORD=
FORWARD_SMTP_FROM=
# STARTTLS (submission/587) vs implicit TLS (SMTPS/465) — mutually exclusive.
FORWARD_SMTP_STARTTLS=true
FORWARD_SMTP_SSL=false


# ---------------------------------------------------------------------------
# External write API — mailboxes + tags CRUD (ADR-0039 / ADR-0040). API only.
#
# The external API (ADR-0029 pull + ADR-0035 reply) is authenticated by
# EXTERNAL_API_KEY. The headless-CRM WRITE section (POST/PATCH/DELETE
# /api/external/mailboxes* + /api/external/tags*) additionally requires an
# explicit opt-in: EXTERNAL_WRITE_ENABLED=true. Default false keeps a read-only
# deployment read-only after an upgrade (a valid key does NOT silently gain
# write capability); when false every write endpoint returns 403 forbidden even
# with a valid key.
#
# EXTERNAL_WRITE_RATE_LIMIT_PER_MINUTE is a SEPARATE per-IP budget from read
# (120) and reply (30) — write is more expensive / abuse-sensitive.
# ---------------------------------------------------------------------------
EXTERNAL_WRITE_ENABLED=false
EXTERNAL_WRITE_RATE_LIMIT_PER_MINUTE=60


# ---------------------------------------------------------------------------
# CI / Build (optional)
# ---------------------------------------------------------------------------
# Image registry prefix.
#   - Local builds (developer machines):  leave empty -> resolves to
#       mail-aggregator/api:${IMAGE_TAG} which `docker compose build` writes.
#   - Prod servers pulling CI-published images: set to the GHCR path, e.g.
#       IMAGE_REGISTRY=ghcr.io/<owner>/<repo>
#     This makes compose pull `ghcr.io/<owner>/<repo>/api:<tag>` instead of
#     trying to rebuild locally.
IMAGE_REGISTRY=

# Tag baked into the image name (${IMAGE_REGISTRY}/api:${IMAGE_TAG}).
# CI sets this to ${{ github.sha }} or a release tag; on the prod server,
# the deploy workflow rewrites this in .env to the freshly-pushed sha.
IMAGE_TAG=local
